            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nasi Box Super Premium\",\n  \"sellPrice\": 40000,\n  \"cogsPrice\": 18000,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "{{product_id}}"]
