    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Mayar Payment Webhook",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-webhook-token",
                "value": "your-mayar-webhook-token",
                "description": "Webhook token from Mayar dashboard"
              }
            ],
